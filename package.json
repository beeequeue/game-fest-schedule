{
  "name": "summergamefest",
  "type": "module",
  "version": "0.0.0",
  "author": "BeeeQueue <adam@haglund.dev>",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": "^26"
  },
  "simple-git-hooks": {
    "pre-commit": "node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,json5,yaml,yml,css,scss,md}": [
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "eslint src",
    "prepare": "simple-git-hooks && svelte-kit sync",
    "start": "node build/index.js",
    "test": "vitest",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@iconify-json/simple-icons": "1.2.84",
    "@sveltejs/adapter-node": "6.0.0-next.0",
    "@sveltejs/kit": "3.0.0-next.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tsconfig/node26": "26.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.9.1",
    "@unocss/extractor-svelte": "66.7.0",
    "@unocss/preset-icons": "66.7.0",
    "@unocss/preset-uno": "66.7.0",
    "@unocss/preset-web-fonts": "66.7.0",
    "@unocss/reset": "66.7.0",
    "@unocss/transformer-directives": "66.7.0",
    "@unocss/vite": "66.7.0",
    "date-fns": "5.0.0-alpha.0",
    "eslint": "10.4.1",
    "eslint-plugin-svelte": "3.19.0",
    "nano-staged": "1.0.2",
    "oxfmt": "0.53.0",
    "simple-git-hooks": "2.13.1",
    "sonda": "0.11.1",
    "svelte": "5.56.2",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
