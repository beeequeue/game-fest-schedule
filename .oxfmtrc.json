{
  "ignorePatterns": ["pnpm-lock.yaml"],
  "semi": false,
  "sortImports": {
    "type": "natural",
    "internalPattern": ["#/", "@/"],
    "groups": ["builtin", "external", "internal", "parent", "sibling", "index", "unknown"]
  },
  "sortPackageJson": false,
  "sortTailwindcss": true,
  "svelte": true
}
